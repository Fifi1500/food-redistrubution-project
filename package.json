{
  "name": "food-surplus-backend",
  "version": "1.0.0",
  "description": "Backend de la plateforme de redistribution des surplus alimentaires",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "nodemon",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- ./src/migrations/Migration -d ./src/config/database.ts",
